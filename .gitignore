# Build artifacts and binaries — never commit these to the repo.

# PyInstaller (star.exe) and zipapp (star.pyz) output
dist/

# Vendored native engines fetched by tools/build-vendor.py
# (ffmpeg, Tesseract, liblouis, Pandoc, DECtalk) — large, re-downloadable.
vendor/

# Private zipapp build — the local-only star-private.pyz machinery (build
# orchestrator, private bootstrap, native-engine fetcher) and its tests. Kept
# out of the public repo; the built artifact itself lands in dist/ (above).
# The canonical home is tools/_private/; the loose filenames are also ignored so
# the build can never be re-tracked regardless of where it lives in the tree.
tools/_private/
build_private_pyz.py
tools/private_bootstrap.py
tools/verify_private_pyz.py
tests/test_private_pyz.py
tests/test_zipapp_private.py
*-private.pyz

# PyInstaller work dir, staged Whisper model, zipapp staging, pip temp, etc.
build/

# Virtual environments (incl. the isolated PyInstaller build env)
.venv/
.venv-build/

# Python bytecode caches and packaging metadata
__pycache__/
*.py[codz]
*.egg-info/

# Test + coverage tooling by-products (pytest-cov powers the tts.py gate)
.coverage
.coverage.*
htmlcov/
coverage.xml
.pytest_cache/

# The docs/ tree is the public documentation set and is tracked in git
# (installation, usage_guide, features, configuration, architecture, and the
# RELEASING runbook).  Do NOT ignore it.

# Internal planning roadmap — a private working document, not tracked.
/ROADMAP.md
# Dated next-steps roadmaps — private working notes, never committed.
/docs/roadmaps/

# Local wiki vault — Obsidian vault used for internal notes, not for the repo.
wiki/

# uv lock file — star ships via pip/setuptools; uv.lock is only a local
# by-product of running tooling under `uv` and is not part of the build.
uv.lock
